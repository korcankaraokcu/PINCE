  <action name="actionAOB_scan_nop">
   <property name="text">
    <string>AOB scan + NOP</string>
   </property>
   <property name="data" stdset="0">
    <string notr="true"># AOB scan + NOP template
[ENABLE]
addr = aobscan_first(&quot;48 8B ?? ?? ?? 89&quot;)
if addr is None:
    raise RuntimeError(&quot;Pattern not found&quot;)
nop(addr, 6)
print(f&quot;NOPed {addr:#x}&quot;)

[DISABLE]
# addr carries over from [ENABLE]
restore(addr)
print(f&quot;Restored {addr:#x}&quot;)</string>
   </property>
  </action>
  <action name="actionAOB_scan_patch">
   <property name="text">
    <string>AOB scan + patch</string>
   </property>
   <property name="data" stdset="0">
    <string notr="true"># AOB scan + patch template
# Example bytes:
# 83 00 FF     add DWORD PTR [rax], 0xffffffff (-0x1)
# 48 8B 43 10  mov rax, QWORD PTR [rbx+0x10]
# This changes the -1 decrement to +2 addition (eg. add ammo when shooting instead of subtracting)
[ENABLE]
expected = &quot;83 00 FF 48 8B 43 10&quot;
addr = aobscan_first(expected)
if addr is None:
    raise RuntimeError(&quot;Pattern not found&quot;)

replacement = assemble(f&quot;&quot;&quot;
add dword ptr [rax], 0x2
&quot;&quot;&quot;, addr)

# Ensure we won't corrupt the next instruction after add
if len(replacement) != 3:
    raise RuntimeError(&quot;Replacement size must match target instruction&quot;)

patch(replacement, addr, expected=&quot;83 00 ff&quot;)
print(f&quot;Patched instruction at {addr:#x}&quot;)

[DISABLE]
# addr carries over from [ENABLE]
restore(addr)
print(f&quot;Restored {addr:#x}&quot;)</string>
   </property>
  </action>
  <action name="actionRead_write_address">
   <property name="text">
    <string>Read/write address</string>
   </property>
   <property name="data" stdset="0">
    <string notr="true"># Read/write template
addr = address(&quot;0x0&quot;)
old_value = read_int(addr, size=4)
write_int(old_value + 1, addr, size=4)
print(f&quot;{addr:#x}: {old_value} -&gt; {read_int(addr, size=4)}&quot;)
</string>
   </property>
  </action>
