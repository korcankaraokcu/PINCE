  <action name="actionCode_injection">
   <property name="text">
    <string>Code injection</string>
   </property>
   <property name="data" stdset="0">
    <string notr="true"># Code injection template
# Prelude runs before both halves.
target = address(&quot;0x0&quot;)

[ENABLE]
cave = alloc(0x400, &quot;engine_code_cave&quot;)
jump_to_cave = assemble(f&quot;jmp {cave:#x}&quot;, target)
# Read enough to cover the jmp patch plus one max-length x86 instruction (15B),
# then round up to the next instruction boundary so we don't leave a partial
# instruction at target after patching.
probe = read_bytes(target, len(jump_to_cave) + 15)
stolen_size = utils.instruction_aligned_size(probe, len(jump_to_cave), debugcore.inferior_arch)
if stolen_size == 0:
    raise RuntimeError(&quot;Could not align stolen bytes to an instruction boundary&quot;)
# RIP-relative instructions in the stolen bytes may need manual adjustment when relocated.
original = probe[:stolen_size]
return_address = target + stolen_size

# Your injection code goes here. The NOPs are a placeholder.
injected_code = assemble(&quot;&quot;&quot;
nop
nop
&quot;&quot;&quot;, cave)

# Cave layout: hook code, then the displaced original bytes, then a jump back.
# Re-executing the original bytes preserves the target's behavior. Drop `+ original` from cave_body to fully replace it.
cave_body = injected_code + original
jump_back = assemble(f&quot;jmp {return_address:#x}&quot;, cave + len(cave_body))
write_bytes(cave_body + jump_back, cave)
# Pad leftover stolen_size bytes with NOPs so execution resumes on a clean
# boundary (a partial instruction left over would corrupt decoding).
patch(jump_to_cave + b&quot;\x90&quot; * (stolen_size - len(jump_to_cave)), target, expected=original)
print(f&quot;Injected {target:#x} -&gt; {cave:#x}, return {return_address:#x}&quot;)

[DISABLE]
restore(target)
dealloc(&quot;engine_code_cave&quot;)
print(f&quot;Restored {target:#x}&quot;)
</string>
   </property>
  </action>
